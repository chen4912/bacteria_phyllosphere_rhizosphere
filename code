  sample_mid_away_OTU <- sample_mid_away_OTU[rowSums(sample_mid_away_OTU) > 0, ]###AWAY_OTU_MID
  
  ### high
  sample_high = unique(c(H_H_H_home, HtoL_away, HtoM_away))
  sample_high_OTU = group_otu_abun[, sample_high]
  sample_high_nohome = unique(c(HtoL_away, HtoM_away))
  sample_high_nohome_OTU = group_otu_abun[, sample_high_nohome]
  
  # Calculate the number of samples for each group
  half_H_H_H_home <- length(M_M_M_home)
  half_HtoL_away <- length(HtoL_away)
  half_HtoM_away <- length(HtoM_away)
  # Keep the OTU that appears in all samples in H_H_H_home 
  H_H_H_home_OTU <- rownames(sample_high_OTU)[rowSums(sample_high_OTU[, H_H_H_home] > 0) >= half_H_H_H_home]
  sample_high_nohome_OTU[H_H_H_home_OTU,]
  #Keep the OTU that appears in all samples in H to L_away 
  HtoL_away_OTU <- rownames(group_otu_abun[, HtoL_away])[rowSums(group_otu_abun[, HtoL_away] > 0) >= half_HtoL_away]
  #Keep the OTU that appears in all samples in H to M_away
  HtoM_away_OTU <- rownames(group_otu_abun[, HtoM_away])[rowSums(group_otu_abun[, HtoM_away] > 0) >= half_HtoM_away]
  # Find the OTU shared by the three groups
  common_OTUs <- Reduce(intersect, list(H_H_H_home_OTU, HtoL_away_OTU, HtoM_away_OTU))
  
  # Get the data of the shared OTUs
  sample_high_home_OTU <- sample_high_nohome_OTU[common_OTUs,]
  sample_high_away_OTU <- sample_high_nohome_OTU[setdiff(rownames(sample_high_nohome_OTU), rownames(sample_high_home_OTU)), ]
  sample_high_away_OTU <- sample_high_away_OTU[rowSums(sample_high_away_OTU) > 0, ]
  
  home_OTU_low_mid <- merge_otu_data(sample_low_home_OTU, sample_mid_home_OTU)
  home_OTU <- merge_otu_data(home_OTU_low_mid, sample_high_home_OTU)
  
  away_OTU_low_mid <- merge_otu_data(sample_low_away_OTU, sample_mid_away_OTU)
  away_OTU <- merge_otu_data(home_OTU_low_mid, sample_high_away_OTU)
  
  final_results_list[[paste("home_OTU", i, sep = "_")]] <- home_OTU
  final_results_list[[paste("away_OTU", i, sep = "_")]] <- away_OTU
}
